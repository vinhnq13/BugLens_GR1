# ─────────────────────────────────────────────────────────────────
# BugLens Backend API — Environment Variables
#
# Copy this file to .env and adjust values for your local setup.
#
# NOTE FOR WINDOWS + DOCKER DESKTOP (WSL2 mode):
# Prisma's Rust engine cannot connect via "localhost" to Docker
# containers when running under WSL2. Use "host.docker.internal"
# as the database host if you are on Windows with Docker Desktop.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection (matches docker-compose.yml defaults)
# Windows + Docker Desktop WSL2:
DATABASE_URL="postgresql://buglens:buglens123@host.docker.internal:5432/buglens_db?schema=public&sslmode=disable"

# Linux / macOS:
# DATABASE_URL="postgresql://buglens:buglens123@localhost:5432/buglens_db?schema=public"

# URL of the AI analysis service
AI_SERVICE_URL="http://localhost:8000"

# Port for the NestJS server
PORT=3000
